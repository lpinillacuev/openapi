    "/v1/payment_methods/installments": {
      "get": {
        "description": {
          "en": "Returns available installment plans for a given card BIN, amount, and site. Use this to populate installment selectors in your checkout.",
          "pt": "TODO",
          "es": "TODO"
        },
        "tags": [
          "Payment Methods"
        ],
        "parameters": [
          {
            "name": "payment_method_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "visa"
          },
          {
            "name": "amount",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "format": "float"
            },
            "example": 1000.0
          },
          {
            "name": "issuer_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bin",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": {
              "en": "First 6 digits of the card (BIN) for more accurate installment pricing",
              "pt": "TODO",
              "es": "TODO"
            },
            "example": "411111"
          }
        ],
        "responses": {
          "200": {
            "description": {
              "en": "Installment options",
              "pt": "TODO",
              "es": "TODO"
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "payment_method_id": {
                        "type": "string"
                      },
                      "payment_type_id": {
                        "type": "string"
                      },
                      "issuer": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer"
                          },
                          "name": {
                            "type": "string"
                          }
                        }
                      },
                      "payer_costs": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "installments": {
                              "type": "integer"
                            },
                            "installment_rate": {
                              "type": "number",
                              "format": "float"
                            },
                            "discount_rate": {
                              "type": "number",
                              "format": "float"
                            },
                            "reimbursement_rate": {
                              "type": "number",
                              "format": "float"
                            },
                            "labels": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "total_amount": {
                              "type": "number",
                              "format": "float"
                            },
                            "installment_amount": {
                              "type": "number",
                              "format": "float"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "title": {
          "en": "Get installment options",
          "pt": "TODO",
          "es": "TODO"
        }

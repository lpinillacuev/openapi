  "components": {
    "schemas": {
      "PreferenceRequest": {
        "type": "object",
        "description": {
          "en": "Request body to create a Checkout Pro preference. The preference generates a hosted checkout URL (init_point) where the payer is redirected to complete payment on MP's UI. Use this for simple integrations; use Orders API for custom checkout experiences.",
          "pt": "TODO",
          "es": "TODO"
        },
        "properties": {
          "items": {
            "type": "array",
            "description": {
              "en": "List of products/services being purchased",
              "pt": "TODO",
              "es": "TODO"
            },
            "items": {
              "$ref": "#/components/schemas/PreferenceItem"
            },
            "minItems": 1
          },
          "payer": {
            "$ref": "#/components/schemas/PreferencePayer"
          },
          "payment_methods": {
            "$ref": "#/components/schemas/PreferencePaymentMethods"
          },
          "shipments": {
            "$ref": "#/components/schemas/PreferenceShipments"
          },
          "back_urls": {
            "$ref": "#/components/schemas/PreferenceBackUrls"
          },
          "notification_url": {
            "type": "string",
            "format": "uri",
            "description": {
              "en": "URL for IPN notifications. DEPRECATED — use Webhooks instead.",
              "pt": "TODO",
              "es": "TODO"
            },
            "deprecated": true
          },
          "statement_descriptor": {
            "type": "string",
            "description": {
              "en": "Text on the payer's card statement. Max 22 chars.",
              "pt": "TODO",
              "es": "TODO"
            },
            "maxLength": 22
          },
          "additional_info": {
            "type": "string",
            "description": {
              "en": "Free-text additional info (returned in webhook notifications)",
              "pt": "TODO",
              "es": "TODO"
            }
          },
          "auto_return": {
            "type": "string",
            "enum": [
              {
                "title": "approved",
                "description": {
                  "en": "approved",
                  "pt": "TODO",
                  "es": "TODO"
                }
              },
              {
                "title": "all",
                "description": {
                  "en": "all",
                  "pt": "TODO",
                  "es": "TODO"
                }
              }
            ],
            "description": {
              "en": "approved — auto-redirect to success URL on approved payments; all — auto-redirect for any final status.",
              "pt": "TODO",
              "es": "TODO"
            }
          },
          "external_reference": {
            "type": "string",
            "description": {
              "en": "Your internal order reference. Returned in webhook payloads.",
              "pt": "TODO",
              "es": "TODO"
            },
            "example": "ORDER-2024-001234"
          },
          "expires": {
            "type": "boolean",
            "description": {
              "en": "Whether this preference has an expiry window",
              "pt": "TODO",
              "es": "TODO"
            },
            "default": false
          },
          "expiration_date_from": {
            "type": "string",
            "format": "date-time",
            "description": {
              "en": "Preference activation start time (ISO 8601)",
              "pt": "TODO",
              "es": "TODO"
            }
          },
          "expiration_date_to": {
            "type": "string",
            "format": "date-time",
            "description": {
              "en": "Preference expiration time (ISO 8601)",
              "pt": "TODO",
              "es": "TODO"
            }
          },
          "marketplace": {
            "type": "string",
            "description": {
              "en": "Marketplace identifier",
              "pt": "TODO",
              "es": "TODO"
            }
          },
          "marketplace_fee": {
            "type": "number",
            "format": "float",
            "description": {
              "en": "Marketplace fee charged to the seller",
              "pt": "TODO",
              "es": "TODO"
            }
          },
          "differential_pricing": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              }
            }
          },
          "binary_mode": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "PreferenceItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "example": "Premium Plan"
          },
          "description": {
            "type": "string"
          },
          "picture_url": {
            "type": "string",
